# Smart Bird configuration. Copy to .env and fill in your values.

# Birdeye Data API key from https://bds.birdeye.so/
BIRDEYE_API_KEY=your_key_here

# Telegram bot credentials from @BotFather and @userinfobot
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id

# Layer 2 — REQUIRED for entry alerts. Comma-separated Solana wallet
# addresses you want to track. Without this, Layer 2 is a no-op and no
# entry alerts will fire (exit alerts still work). Example real wallet:
#   SMART_MONEY_WALLETS=GJRs4FwHtemZ5ZE9x3FNvJ8TMwitKTh21yxdRPqn7npE
SMART_MONEY_WALLETS=

# Layer 1 honeypot/mintable/rug security screen.
#
# Birdeye's /defi/token_security endpoint requires Lite tier or higher.
# If your API key is on the Standard (free) tier, this endpoint returns
# 401/403 and every token gets dropped as "can't verify". Set this to
# 'false' to skip the security screen entirely (Layer 1 still scores on
# volume/holders/buy pressure/trajectory). A loud warning is logged at
# startup so you don't forget you're running without the rug filter.
SECURITY_SCREEN_REQUIRED=true

# Per-layer alert channels. All default ON — set to 'false' to silence
# individual channels. The combined SMART BIRD ALERT (all three layers
# aligned) is always on and cannot be disabled.
ENABLE_GRADUATION_ALERTS=true
ENABLE_SMART_MONEY_ALERTS=true
ENABLE_EXIT_ALERTS=true

# Layer 1 graduation score threshold (0–100, default 65)
GRADUATION_SCORE_THRESHOLD=65

# Layer 3 liquidity drop threshold as a fraction (default 0.20 = 20%)
LIQUIDITY_DROP_THRESHOLD=0.20

# Polling interval for Layer 1 in seconds (default 60)
POLL_INTERVAL_SECONDS=60

# On-disk paths.
#
# The Docker image mounts /data as a persistent volume, so the in-container
# defaults are /data/smart-bird.db and /data/api_calls.log.
#
# For local (non-Docker) runs, override these to a path your user can write to.
# Uncomment the lines below if running outside Docker:
# DB_PATH=./smart-bird.db
# API_CALLS_LOG=./api_calls.log

# Layer 1 pass gate \u2014 minimum holder count for a token to pass (default 20).
# Fresh Pump.fun launches often have <50 holders in the first 5 minutes; lower
# this to 5-10 if you want earlier Graduation Watch alerts, higher (e.g. 100)
# for safer but fewer passes.
MIN_HOLDER_COUNT=20

# Layer 1 pass gate \u2014 minimum buy/sell ratio (default 0.55 = 55%).
MIN_BUY_PRESSURE=0.55
